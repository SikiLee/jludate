# 必填安全密钥
# 生产环境请使用足够长的随机字符串。
SECRET_KEY=replace-with-a-long-random-secret

# 必填隐私密钥环（base64 编码的 32 字节密钥），JSON 格式。
# 示例值仅用于本地开发。
PRIVACY_KEYRING_JSON={"v1":"MDEyMzQ1Njc4OWFiY2RlZjAxMjM0NTY3ODlhYmNkZWY="}

# 可选 SMTP 配置
SMTP_ENABLED=false
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_REQUIRE_TLS=false
SMTP_TLS_REJECT_UNAUTHORIZED=true
WEB_BASE_URL=http://localhost:8383

# 可选测试/调试开关
ALLOW_TEST_TRIGGER=false
EXPOSE_VERIFICATION_CODE_FOR_TESTS=false

# 当 site_settings 尚未初始化时使用的默认邮箱白名单域名。
# 支持逗号/换行分隔，或 JSON 数组。
# 示例：
# DEFAULT_ALLOWED_EMAIL_DOMAINS=szu.edu.cn,thu.edu.cn
# DEFAULT_ALLOWED_EMAIL_DOMAINS=*.edu.cn
# DEFAULT_ALLOWED_EMAIL_DOMAINS=["szu.edu.cn","thu.edu.cn"]
DEFAULT_ALLOWED_EMAIL_DOMAINS=szu.edu.cn

# 可选初始化账号（默认关闭，出于安全考虑）
ENABLE_DEFAULT_USERS_BOOTSTRAP=false
DEFAULT_ADMIN_EMAIL=
DEFAULT_ADMIN_PASSWORD=
DEFAULT_USER_EMAIL=
DEFAULT_USER_PASSWORD=
